# =============================================================================
# SENSITIVE variables — copy to secrets.tfvars (GITIGNORED)
# =============================================================================
# Usage:
#   cp secrets.tfvars.example secrets.tfvars
#   # edit secrets.tfvars with real values (never commit)
#   terraform apply -var-file=terraform.tfvars -var-file=secrets.tfvars
#
# Preferred in CI/CD:
#   export TF_VAR_database_username="..."
#   export TF_VAR_database_password="..."
#   export TF_VAR_jwt_secret="..."
#   export TF_VAR_rabbitmq_username="..."
#   export TF_VAR_rabbitmq_password="..."
# =============================================================================

database_username = "REPLACE_ME"
database_password = "REPLACE_ME"
jwt_secret        = "REPLACE_ME_minimum_thirty_two_characters"
rabbitmq_username = "REPLACE_ME"
rabbitmq_password = "REPLACE_ME"
