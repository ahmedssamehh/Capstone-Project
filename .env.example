# =============================================================================
# WorkHub Docker Stack — Environment Variables (LOCAL DEVELOPMENT ONLY)
# =============================================================================
#
# SECURITY:
#   - Copy to .env:  cp .env.example .env
#   - Never commit .env (listed in .gitignore)
#   - Replace ALL CHANGE_ME values before any shared/staging environment
#   - Production: inject via secret manager (AWS SM, Vault, K8s Secrets)
#
# Startup:
#   docker compose up --build -d
# =============================================================================

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_DB=workhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_dev_only
POSTGRES_PORT=5432

# --- RabbitMQ (management UI on :15672) -----------------------------------
RABBITMQ_USERNAME=workhub
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_dev_only
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_VHOST=/

# --- WorkHub API ------------------------------------------------------------
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# JWT HS256 — minimum 32 characters; generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Messaging topology (must match RabbitMQConfig.java)
WORKHUB_RABBIT_EXCHANGE=workhub.jobs.direct
WORKHUB_RABBIT_QUEUE=workhub.jobs.queue
WORKHUB_RABBIT_ROUTING_KEY=workhub.jobs.process

# Optional JVM overrides (image sets container-aware defaults)
# JAVA_OPTS=-XX:MaxRAMPercentage=75.0
